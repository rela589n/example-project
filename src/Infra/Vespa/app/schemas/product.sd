schema product {
	document product {
	    field title type string {
			indexing: index | summary
	    }
	    field description type string {
	    	indexing: index # is available in summary because used in "main" summary even though it might not be used
	    }
	    field category type string {
	    	indexing: index | summary # requires explicit summary
	    }
	    field priceUnitAmount type int {
			indexing: summary # requires explicit summary
	    }
	}
	field gemma_embedding type tensor<float>(dim[768]) {
		indexing: input description | embed embed-gemma-300m-q8 | attribute
		attribute {
			# must match metric used by model
			distance-metric: angular
		}
	}
	rank-profile gemma_closeness {
		inputs {
		    query(query_embedding) tensor<float>(dim[768])
		}
		first-phase {
		    expression: embedding_score()
		}
		function embedding_score() {
			expression: closeness(field, gemma_embedding)
		}
		match-features {
		    embedding_score()
		}
	}
	document-summary main {
		summary title {}
		summary description {}
	}
}
