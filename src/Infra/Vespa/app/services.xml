<?xml version="1.0" encoding="utf-8" ?>
<services version="1.0">
    <!--
     Container cluster - api server - stateless, handles requests (search queries, document operations)
     High query load? → Add container nodes
    -->
    <container id="default" version="1.0">
        <search/> <!-- query search api endpoint -->
        <document-api/> <!-- document feed api endpoint -->
        <nodes>
            <node hostalias="node1"/>
        </nodes>
        <!-- see https://huggingface.co/google/embeddinggemma-300m -->
        <component id="embed-gemma-300m-q8" type="hugging-face-embedder">
            <tokenizer-model url="https://huggingface.co/onnx-community/embeddinggemma-300m-ONNX/resolve/main/tokenizer.json"/>
            <transformer-model url="https://huggingface.co/onnx-community/embeddinggemma-300m-ONNX/resolve/main/onnx/model_quantized.onnx"/>
            <!-- See https://github.com/vespa-engine/pyvespa/blob/dc1d0c8afa0661f7dbf7104b435cebf54a393dde/vespa/models.py#L814-L825 for configuration -->
            <max-tokens>2048</max-tokens>
            <prepend>
                <query>task: search result | query: </query>
                <document>title: none | text: </document>
            </prepend>
        </component>
        <component id="colbert" type="colbert-embedder">
            <tokenizer-model url="https://huggingface.co/colbert-ir/colbertv2.0/raw/main/tokenizer.json"/>
            <transformer-model url="https://huggingface.co/colbert-ir/colbertv2.0/resolve/main/model.onnx"/>
            <max-query-tokens>32</max-query-tokens>
            <max-document-tokens>128</max-document-tokens>
        </component>
    </container>
    <!--
    Content cluster - stateful, stores documents and indexes
    More data? → Add content nodes
    -->
    <content id="content" version="1.0">
        <redundancy>1</redundancy> <!-- 1 copy of data (no replication) -->
        <documents> <!-- Links your schema -->
            <document type="greeting" mode="index"/>
            <document type="msmarco" mode="index"/>
            <document type="product" mode="index"/>
        </documents>
        <nodes>
            <node hostalias="node1" distribution-key="0"/>
        </nodes>
    </content>
</services>
